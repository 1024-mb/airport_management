<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="311.0" prefWidth="309.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airport_management.controller.databaseController">
   <children>
      <Label alignment="CENTER" layoutX="1.0" prefHeight="17.0" prefWidth="308.0" text="Edit Details">
         <font>
            <Font size="22.0" />
         </font>
      </Label>
      <Label layoutX="13.0" layoutY="60.0" prefHeight="23.0" prefWidth="77.0" text="Manufacturer" />
      <TextField fx:id="Plane_Manufacturer" layoutX="121.0" layoutY="58.0" prefHeight="26.0" prefWidth="174.0" />
      <Label layoutX="13.0" layoutY="96.0" prefHeight="25.0" prefWidth="70.0" text="Model" />
      <TextField fx:id="Plane_Model" layoutX="122.0" layoutY="96.0" prefHeight="26.0" prefWidth="174.0" />
      <Label layoutX="13.0" layoutY="134.0" prefHeight="25.0" prefWidth="73.0" text="Passengers" />
      <TextField fx:id="Plane_Passengers" layoutX="122.0" layoutY="134.0" prefHeight="26.0" prefWidth="174.0" />
      <Label layoutX="13.0" layoutY="214.0" prefHeight="26.0" prefWidth="73.0" text="PlaneLayout" />
      <TextField fx:id="Plane_PlaneLayout" layoutX="123.0" layoutY="214.0" prefHeight="26.0" prefWidth="174.0" />
      <Button fx:id="submitButton" layoutX="73.0" layoutY="268.0" mnemonicParsing="false" styleClass="button_confirm" text="Submit" />
      <Button fx:id="cancelButton" layoutX="175.0" layoutY="268.0" mnemonicParsing="false" styleClass="button_confirm" text="Cancel" />
      <Label layoutX="13.0" layoutY="173.0" prefHeight="26.0" prefWidth="93.0" text="FlightAttendants" />
      <TextField fx:id="Plane_FlightAttendants" layoutX="123.0" layoutY="173.0" prefHeight="26.0" prefWidth="174.0" />

      <Label fx:id="error_msg" alignment="CENTER" contentDisplay="CENTER" layoutX="6.0" layoutY="25.0" prefHeight="17.0" prefWidth="297.0" textFill="#9e2a2b" />
   </children>
</AnchorPane>
